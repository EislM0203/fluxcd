[Unit]
Description=OpenShell Gateway ({{ openshell_compute_driver }} driver)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ openshell_user }}
Group={{ openshell_group }}
{% if openshell_compute_driver == 'vm' %}
SupplementaryGroups=kvm
{% elif openshell_compute_driver == 'docker' %}
SupplementaryGroups=docker
{% endif %}
Environment=HOME={{ openshell_home }}
Environment=XDG_CONFIG_HOME={{ openshell_home }}/.config
Environment=XDG_STATE_HOME={{ openshell_home }}/.local/state
Environment=XDG_DATA_HOME={{ openshell_home }}/.local/share
{% if openshell_compute_driver == 'podman' %}
# Rootless podman socket at $XDG_RUNTIME_DIR/podman/podman.sock. Literal UID — %U resolves
# to the service manager (0) in system units, not User=.
Environment=XDG_RUNTIME_DIR=/run/user/{{ openshell_uid }}
{% else %}
Environment=XDG_RUNTIME_DIR=/run/openshell
RuntimeDirectory=openshell
{% endif %}
EnvironmentFile={{ openshell_config_dir }}/gateway.env
ExecStart={{ openshell_bin_dir }}/openshell-gateway --config {{ openshell_config_dir }}/gateway.toml
{% if openshell_compute_driver == 'podman' %}
# Reboot recovery: sandboxes are created with restart=no and OpenShell has no `sandbox
# start`. `sandbox delete` runs `podman rm`, so --all only revives live sandboxes. Gateway
# re-adopts via supervisor reconnect (verified 2026-05-29).
ExecStartPost=/usr/bin/podman start --all
{% endif %}
Restart=on-failure
RestartSec=5s

# Light hardening; drivers need userns/mounts/per-sandbox networking. Tighten later.
ProtectSystem=full
ProtectHome=false
PrivateTmp=false
NoNewPrivileges=false
ReadWritePaths={{ openshell_home }}

[Install]
WantedBy=multi-user.target
