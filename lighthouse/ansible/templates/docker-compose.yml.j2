name: pangolin

networks:
  default:
    driver: bridge
    name: pangolin

services:
  pangolin:
    image: docker.io/fosrl/pangolin:{{ image_pangolin }}
    container_name: pangolin
    restart: unless-stopped
    volumes:
      - ./config:/app/config
    security_opt:
      - no-new-privileges:true
    mem_limit: 1g
    pids_limit: 200
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3001/api/v1/"]
      interval: 3s
      timeout: 3s
      retries: 15

  gerbil:
    image: docker.io/fosrl/gerbil:{{ image_gerbil }}
    container_name: gerbil
    restart: unless-stopped
    depends_on:
      pangolin:
        condition: service_healthy
    command:
      - --reachableAt=http://gerbil:3004
      - --generateAndSaveKeyTo=/var/config/key
      - --remoteConfig=http://pangolin:3001/api/v1/
    volumes:
      - ./config/:/var/config
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    security_opt:
      - no-new-privileges:true
    mem_limit: 512m
    pids_limit: 200
    ports:
      - 51820:51820/udp
      - 21820:21820/udp
      - 443:443
      - 80:80

  traefik:
    image: docker.io/traefik:{{ image_traefik }}
    container_name: traefik
    restart: unless-stopped
    network_mode: service:gerbil
    depends_on:
      pangolin:
        condition: service_healthy
      crowdsec:
        condition: service_healthy
    command:
      - --configFile=/etc/traefik/traefik_config.yml
    environment:
      CF_DNS_API_TOKEN: "{{ cloudflare_token }}"
    volumes:
      - ./config/traefik:/etc/traefik:ro
      - ./config/letsencrypt:/letsencrypt
      - ./config/logs:/var/log/traefik
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
      - DAC_OVERRIDE
      - CHOWN
      - FOWNER
    security_opt:
      - no-new-privileges:true
    mem_limit: 512m
    pids_limit: 200

  crowdsec:
    image: docker.io/crowdsecurity/crowdsec:{{ image_crowdsec }}
    container_name: crowdsec
    restart: unless-stopped
    environment:
      COLLECTIONS: "crowdsecurity/traefik crowdsecurity/appsec-virtual-patching crowdsecurity/appsec-generic-rules crowdsecurity/base-http-scenarios crowdsecurity/http-cve crowdsecurity/appsec-crs"
      PARSERS: "crowdsecurity/whitelists"
      GID: "1000"
    volumes:
      - ./config/crowdsec:/etc/crowdsec
      - ./config/crowdsec/db:/var/lib/crowdsec/data
      - ./config/logs:/var/log/traefik
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - DAC_OVERRIDE
      - FOWNER
      - SETUID
      - SETGID
    security_opt:
      - no-new-privileges:true
    mem_limit: 768m
    pids_limit: 300
    healthcheck:
      test: ["CMD", "cscli", "lapi", "status"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 30s

  crowdsec-manager:
    image: docker.io/hhftechnology/crowdsec-manager:2.4.1
    container_name: crowdsec-manager
    restart: unless-stopped
    depends_on:
      crowdsec:
        condition: service_healthy
    environment:
      PORT: "8080"
      ENVIRONMENT: production
      LOG_LEVEL: info
      DOCKER_HOST: unix:///var/run/docker.sock
      COMPOSE_FILE: /app/docker-compose.yml
      PANGOLIN_DIR: /app
      CONFIG_DIR: /app/config
      DATABASE_PATH: /app/data/settings.db
      # Paths below are read INSIDE the target container via docker exec (not bind-mounted here).
      TRAEFIK_CONTAINER_NAME: traefik
      TRAEFIK_DYNAMIC_CONFIG: /etc/traefik/dynamic_config.yml
      TRAEFIK_STATIC_CONFIG: /etc/traefik/traefik_config.yml
      CROWDSEC_METRICS_URL: http://crowdsec:6060/metrics
      BACKUP_DIR: /app/backups
      RETENTION_DAYS: "60"
      ALERT_LIST_LIMIT: "5000"
      INCLUDE_CROWDSEC: "false"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - ./docker-compose.yml:/app/docker-compose.yml
      - ./config:/app/config
      - ./crowdsec-manager/data:/app/data
      - ./crowdsec-manager/backups:/app/backups
    mem_limit: 512m
    pids_limit: 200
