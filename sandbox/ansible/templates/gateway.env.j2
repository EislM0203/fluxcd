# database_url is rejected in TOML — must be an env var
OPENSHELL_DB_URL=sqlite:{{ openshell_state_dir }}/gateway/openshell.db
# Transport mTLS (env > TOML; avoids guessing the tls sub-schema)
OPENSHELL_TLS_CERT={{ openshell_pki_dir }}/server/tls.crt
OPENSHELL_TLS_KEY={{ openshell_pki_dir }}/server/tls.key
OPENSHELL_TLS_CLIENT_CA={{ openshell_pki_dir }}/ca.crt
OPENSHELL_ENABLE_MTLS_AUTH=true
